# ==========================================
# DATABASE MANAGEMENT CLASS
# ==========================================
class Database:
    def __init__(self, db_path):
        self.db_path = db_path
        self.init_db()

    def get_conn(self):
        """Ma'lumotlar bazasiga xavfsiz ulanish yaratish"""
        conn = sqlite3.connect(self.db_path, timeout=20.0)
        conn.row_factory = sqlite3.Row
        return conn

    def init_db(self):
        """Barcha kerakli jadvallarni yaratish va dastlabki sozlash"""
        with self.get_conn() as conn:
            cursor = conn.cursor()
            
            # Users jadvali
            cursor.execute("""
            CREATE TABLE IF NOT EXISTS users (
                user_id INTEGER PRIMARY KEY,
                username TEXT,
                first_name TEXT,
                join_date TEXT,
                is_banned INTEGER DEFAULT 0
            )
            """)
            
            # Premium foydalanuvchilar jadvali
            cursor.execute("""
            CREATE TABLE IF NOT EXISTS premium_users (
                user_id INTEGER PRIMARY KEY,
                premium_until TEXT,
                FOREIGN KEY(user_id) REFERENCES users(user_id)
            )
            """)
            
            # Yuklanmalar tarixi va kunlik limitlar jadvali
            cursor.execute("""
            CREATE TABLE IF NOT EXISTS downloads (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                download_date TEXT,
                media_type TEXT,
                url TEXT
            )
            """)
            
            # Bot sozlamalari jadvali
            cursor.execute("""
            CREATE TABLE IF NOT EXISTS settings (
                key TEXT PRIMARY KEY,
                value TEXT
            )
            """)
            
            # Tizim loglari jadvali (Baza ichida ham saqlash uchun)
            cursor.execute("""
            CREATE TABLE IF NOT EXISTS logs (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT,
                level TEXT,
                message TEXT
            )
            """)
            
            conn.commit()

    def register_user(self, user_id, username, first_name):
        """Foydalanuvchini bazaga qo'shish yoki yangilash"""
        now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("""
            INSERT INTO users (user_id, username, first_name, join_date)
            VALUES (?, ?, ?, ?)
            ON CONFLICT(user_id) DO UPDATE SET
                username = excluded.username,
                first_name = excluded.first_name
            """, (user_id, username, first_name, now))
            conn.commit()

    def is_banned(self, user_id):
        """Foydalanuvchi bloklanganligini tekshirish"""
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT is_banned FROM users WHERE user_id = ?", (user_id,))
            row = cursor.fetchone()
            return row and row['is_banned'] == 1

    def set_ban(self, user_id, status=1):
        """Foydalanuvchini bloklash yoki blokdan chiqarish"""
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("UPDATE users SET is_banned = ? WHERE user_id = ?", (status, user_id))
            conn.commit()

    def check_premium(self, user_id):
        """Foydalanuvchining premium statusini va muddatini tekshirish"""
        if user_id == ADMIN_ID:
            return True, "Cheksiz (Admin)"
        
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT premium_until FROM premium_users WHERE user_id = ?", (user_id,))
            row = cursor.fetchone()
            if row:
                until_date = datetime.strptime(row['premium_until'], "%Y-%m-%d %H:%M:%S")
                if until_date > datetime.now():
                    return True, row['premium_until']
                else:
                    # Muddat tugagan bo'lsa o'chirish
                    cursor.execute("DELETE FROM premium_users WHERE user_id = ?", (user_id,))
                    conn.commit()
            return False, None

    def give_premium(self, user_id, days):
        """Foydalanuvchiga kunlik hisobda premium muddatini berish"""
        until_date = (datetime.now() + timedelta(days=days)).strftime("%Y-%m-%d %H:%M:%S")
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("""
            INSERT INTO premium_users (user_id, premium_until)
            VALUES (?, ?)
            ON CONFLICT(user_id) DO UPDATE SET premium_until = excluded.premium_until
            """, (user_id, until_date))
            conn.commit()

    def remove_premium(self, user_id):
        """Premium statusini bekor qilish"""
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("DELETE FROM premium_users WHERE user_id = ?", (user_id,))
            conn.commit()

    def log_download(self, user_id, media_type, url):
        """Yuklab olish harakatini qayd etish"""
        now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("""
            INSERT INTO downloads (user_id, download_date, media_type, url)
            VALUES (?, ?, ?, ?)
            """, (user_id, now, media_type, url))
            conn.commit()

    def get_daily_usage(self, user_id, media_type):
        """Foydalanuvchining bugungi kunda yuklagan fayllari sonini aniqlash"""
        today_start = datetime.now().strftime("%Y-%m-%d 00:00:00")
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("""
            SELECT COUNT(*) as cnt FROM downloads 
            WHERE user_id = ? AND media_type = ? AND download_date >= ?
            """, (user_id, media_type, today_start))
            row = cursor.fetchone()
            return row['cnt'] if row else 0

    def get_stats(self):
        """Admin panel uchun to'liq bot statistikasini yig'ish"""
        today_start = datetime.now().strftime("%Y-%m-%d 00:00:00")
        stats = {}
        with self.get_conn() as conn:
            cursor = conn.cursor()
            
            cursor.execute("SELECT COUNT(*) as total FROM users")
            stats['total_users'] = cursor.fetchone()['total']
            
            cursor.execute("SELECT COUNT(*) as today FROM users WHERE join_date >= ?", (today_start,))
            stats['today_users'] = cursor.fetchone()['today']
            
            cursor.execute("SELECT COUNT(*) as prem FROM premium_users")
            stats['premium_users'] = cursor.fetchone()['prem']
            
            cursor.execute("SELECT COUNT(*) as dl FROM downloads")
            stats['total_downloads'] = cursor.fetchone()['dl']
            
            cursor.execute("""
                SELECT user_id, COUNT(*) as cnt FROM downloads 
                GROUP BY user_id ORDER BY cnt DESC LIMIT 5
            """)
            stats['top_users'] = cursor.fetchall()
            
        return stats

    def get_all_users(self):
        """Hamma foydalanuvchilar ID ro'yxatini olish (Broadcast uchun)"""
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT user_id FROM users")
            return [row['user_id'] for row in cursor.fetchall()]

    def write_system_log(self, level, message):
        """Baza ichki log tizimi"""
        now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with self.get_conn() as conn:
            cursor = conn.cursor()
            cursor.execute("INSERT INTO logs (timestamp, level, message) VALUES (?, ?, ?)", (now, level, message))
            conn.commit()

db = Database(DB_NAME)

# ==========================================
# HELPER & UTILITY FUNCTIONS
