def check_channel_subscription(user_id):
    """Majburiy obunani tekshirish funksiyasi"""
    if not CHANNELS:
        return True
    if user_id == ADMIN_ID:
        return True
    
    for channel in CHANNELS:
        try:
            member = bot.get_chat_member(channel, user_id)
            if member.status in ['left', 'kicked']:
                return False
        except Exception as e:
            err_logger.error(f"Kanal obunasini tekshirishda xatolik ({channel}): {e}")
            # Agar bot kanalda admin bo'lmasa yoki kanal topilmasa xatolik chiqadi, o'tkazib yuboriladi
            continue
    return True

def clean_old_downloads():
    """Yuklab olingan va keshda qolgan fayllarni tozalash (Avtomatik boshqariladi)"""
    try:
        now = time.time()
        for filename in os.listdir(DOWNLOAD_DIR):
            filepath = os.path.join(DOWNLOAD_DIR, filename)
            # 1 soatdan ko'p turgan fayllarni o'chirish
            if os.path.getmtime(filepath) < now - 3600:
                if os.path.isfile(filepath) or os.path.islink(filepath):
                    os.unlink(filepath)
                elif os.path.isdir(filepath):
                    shutil.rmtree(filepath)
    except Exception as e:
        err_logger.error(f"Keshni tozalashda xatolik yuz berdi: {e}")

def clean_old_downloads():
    """Yuklab olingan va keshda qolgan fayllarni tozalash (Avtomatik boshqariladi)"""
    try:
        now = time.time()
        for filename in os.listdir(DOWNLOAD_DIR):
            filepath = os.path.join(DOWNLOAD_DIR, filename)
            # 1 soatdan ko'p turgan fayllarni o'chirish
            if os.path.getmtime(filepath) < now - 3600:
                if os.path.isfile(filepath) or os.path.islink(filepath):
                    os.unlink(filepath)
                elif os.path.isdir(filepath):
                    shutil.rmtree(filepath)
    except Exception as e:
        err_logger.error(f"Keshni tozalashda xatolik yuz berdi: {e}")

def get_main_keyboard(user_id):
    """Asosiy reply tugmalarni shakllantirish"""
    is_prem, _ = db.check_premium(user_id)
    kb = types.ReplyKeyboardMarkup(resize_keyboard=True, row_width=2)
    btn1 = types.KeyboardButton("👤 Profil va Limitlar")
    btn2 = types.KeyboardButton("ℹ️ Bot Haqida")
    kb.add(btn1, btn2)
    if user_id == ADMIN_ID:
        btn_admin = types.KeyboardButton("⚙️ Admin Panel")
        kb.add(btn_admin)
    return kb

def get_subscription_keyboard():
    """Majburiy obuna inline tugmalarini shakllantirish"""
    kb = types.InlineKeyboardMarkup(row_width=1)
    for idx, channel in enumerate(CHANNELS, start=1):
        url = f"https://t.me/{channel.replace('@', '')}"
        kb.add(types.InlineKeyboardButton(text=f"📣 {idx}-Kanalga a'zo bo'lish", url=url))
    kb.add(types.InlineKeyboardButton(text=f"✅ Tekshirish", callback_data="check_subs"))
    return kb

# ==========================================
# MIDDLEWARES & FILTER GUARDS
# ==========================================
@bot.middleware_handler(update_types=['message'])
def anti_flood_and_ban_middleware(bot_instance, message):
    """Spamga qarshi va ban holatini tekshiruvchi global himoya qatlam"""
    if not message.from_user:
        return

    user_id = message.from_user.id
    
    # 1. Ban nazorati
    if db.is_banned(user_id):
        bot.send_message(user_id, "🚫 <b>Siz botdan foydalanishdan chetlashtirilgansiz!</b>")
        return telebot.handler_backends.CancelUpdate()

    # 2. Flood/Spam nazorati
    current_time = time.time()
    last_time = user_last_action[user_id]
    if current_time - last_time < FLOOD_THRESHOLD:
        bot.send_message(user_id, "⚠️ <b>Iltimos, ketma-ket tez so'rov yubormang. Biroz kuting!</b>")
        user_last_action[user_id] = current_time
        return telebot.handler_backends.CancelUpdate()
    
    user_last_action[user_id] = current_time
    
    # 3. Foydalanuvchini ro'yxatga olish / yangilash
    db.register_user(user_id, message.from_user.username, message.from_user.first_name)
    user_logger.info(f"User {user_id} -> {message.text or '[Media/Action]'}")

