# ==========================================
# LOGGING SYSTEM CONFIGURATION
# ==========================================
formatter = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')

def setup_logger(name, log_file, level=logging.INFO):
    """Alohida fayllar uchun loggerni sozlash funksiyasi"""
    handler = logging.FileHandler(os.path.join(LOG_DIR, log_file), encoding='utf-8')
    handler.setFormatter(formatter)
    logger = logging.getLogger(name)
    logger.setLevel(level)
    logger.addHandler(handler)
    return logger

err_logger = setup_logger('errors_log', 'errors.log', logging.ERROR)
user_logger = setup_logger('users_log', 'users.log', logging.INFO)
dl_logger = setup_logger('downloads_log', 'downloads.log', logging.INFO)

