            f"📊 <b>Bugungi qolgan limitlaringiz:</b>\n"
            f"🎬 <b>Video yuklash:</b> {v_limit_str}\n"
            f"🎵 <b>Audio/Shazam:</b> {a_limit_str}\n"
        )
        bot.send_message(user_id, profile_text)
        
    elif message.text == "ℹ️ Bot Haqida":
        about_text = (
            f"🤖 <b>Universal Media Downloader Bot</b>\n\n"
            f"Ushbu bot eng mashhur ijtimoiy tarmoqlardan yuqori tezlikda multimedia kontentlarini yuklab berish va "
            f"Shazam texnologiyasi orqali musiqalarni tezkor qidirib topish uchun yaratilgan.\n\n"
            f"⚠️ Bot yuklanayotgan fayllarning mualliflik huquqiga javobgar emas. Tizim avtomatlashtirilgan."
        )
        bot.send_message(user_id, about_text)

@bot.callback_query_handler(func=lambda call: call.data == "check_subs")
def callback_subscription_check(call):
    user_id = call.from_user.id
    if check_channel_subscription(user_id):
        bot.answer_callback_query(call.id, "✅ Rahmat! Obuna tasdiqlandi.", show_alert=True)
        bot.delete_message(chat_id=user_id, message_id=call.message.message_id)
        bot.send_message(user_id, "🚀 Bot ishga tushdi! Havola yuborishingiz mumkin.", reply_markup=get_main_keyboard(user_id))
    else:
        bot.answer_callback_query(call.id, "❌ Siz hali barcha kanallarga obuna bo'lmagansiz!", show_alert=True)

# ==========================================
# SHAZAM AUDIO IDENTIFICATION ENGINE
# ==========================================
async def process_shazam_search(file_path):
    """Shazam API orqali audio faylni aniqlash"""
    shazam = Shazam()
    try:
        out = await shazam.recognize(file_path)
        if out and 'track' in out:
            track = out['track']
            title = track.get('title', 'Noma\'lum')
            artist = track.get('subtitle', 'Noma\'lum')
            # Muqova rasmi
            images = track.get('images', {})
            cover_url = images.get('coverarthq', images.get('coverart', None))
            return {"status": True, "title": title, "artist": artist, "cover": cover_url}
        return {"status": False, "message": "Musiqa topilmadi 😔"}
    except Exception as e:
        err_logger.error(f"Shazam tanib olish xatosi: {e}")
        return {"status": False, "message": f"Xato yuz berdi: {str(e)}"}

@bot.message_handler(content_types=['voice', 'audio'])
def voice_audio_shazam_handler(message):
    user_id = message.from_user.id
    if not check_channel_subscription(user_id):
        bot.send_message(user_id, "⚠️ Avval kanallarga a'zo bo'ling.", reply_markup=get_subscription_keyboard())
        return

    # Limitlarni tekshirish
    is_prem, _ = db.check_premium(user_id)
    if not is_prem:
        used = db.get_daily_usage(user_id, 'audio')
        if used >= DAILY_AUDIO_LIMIT:
            bot.send_message(user_id, f"❌ <b>Kunlik qidiruv va audio limitingiz ({DAILY_AUDIO_LIMIT} ta) tugadi!</b>\nPremium sotib olish uchun adminga murojaat qiling.")
            return

    status_msg = bot.send_message(user_id, "🔍 <b>Musiqa tahlil qilinmoqda... Iltimos kuting.</b>")
    
    try:
        file_id = message.voice.file_id if message.content_type == 'voice' else message.audio.file_id
        file_info = bot.get_file(file_id)
        
        # Faylni yuklab olish
        ext = file_info.file_path.split('.')[-1]
        local_filename = f"shazam_{user_id}_{int(time.time())}.{ext}"
        local_path = os.path.join(DOWNLOAD_DIR, local_filename)
        
        downloaded_file = bot.download_file(file_info.file_path)
        with open(local_path, 'wb') as new_file:
            new_file.write(downloaded_file)
            
        # Asinxron shazam funksiyasini chaqirish
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        result = loop.run_until_complete(process_shazam_search(local_path))
        loop.close()
        
        if result['status']:
            caption = f"🎵 <b>Musiqa topildi!</b>\n\n📌 <b>Nomi:</b> {result['title']}\n🎤 <b>Ijrochi:</b> {result['artist']}"
            db.log_download(user_id, 'audio', f"Shazam: {result['artist']} - {result['title']}")
            dl_logger.info(f"User {user_id} identified music via Shazam: {result['artist']} - {result['title']}")
            
            if result['cover']:
                bot.send_photo(user_id, result['cover'], caption=caption)
            else:
                bot.send_message(user_id, caption)
        else:
            bot.send_message(user_id, result['message'])
            
        # Ishlatilgan faylni tozalash
        if os.path.exists(local_path):
            os.remove(local_path)
            
    except Exception as e:
        err_logger.error(f"Shazam handler xatosi: {e}")
        bot.send_message(user_id, "❌ Audio faylni tahlil qilishda xatolik yuz berdi.")
    finally:
        bot.delete_message(chat_id=user_id, message_id=status_msg.message_id)
        clean_old_downloads()

# ==========================================
# YT-DLP MEDIA DOWNLOAD CORE ENGINE
# ==========================================
def download_media_ytdlp(url, mode='video'):
    """yt-dlp orqali universal yuklash yadrosi"""
    timestamp = int(time.time())
    
    # Har qanday tarmoq uchun eng universal yuklash sozlamalari
    ydl_opts = {
        'outtmpl': os.path.join(DOWNLOAD_DIR, f'media_dl_{timestamp}_%(id)s.%(ext)s'),
        'quiet': True,
        'no_warnings': True,
        'ignoreerrors': False,
    }
    
    if mode == 'audio':
        ydl_opts.update({
            'format': 'bestaudio/best',
            'postprocessors': [{
                'key': 'FFmpegExtractAudio',
                'preferredcodec': 'mp3',
                'preferredquality': '192',
            }],
        })
    else:
        # Eng muvofiq video formatni aniqlash (Telegram mos kelishi va 50MB dan oshmasligi uchun)
        ydl_opts.update({
            'format': 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best',
        })

    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=True)
            if 'entries' in info:
                # Agar playlist bo'lsa, birinchi elementni olamiz
                info = info['entries'][0]
                
            filename = ydl.prepare_filename(info)
            if mode == 'audio':
                # MP3 o'zgarishini inobatga olish
                filename = os.path.splitext(filename)[0] + ".mp3"
                
            return {"status": True, "filepath": filename, "title": info.get('title', 'Media')}
    except Exception as e:
        err_logger.error(f"yt-dlp xatoligi URL: {url} | Xato: {e}")
        return {"status": False, "message": str(e)}

@bot.message_handler(func=lambda msg: msg.text and (msg.text.startswith("http://") or msg.text.startswith("https://")))
def incoming_links_handler(message):
    user_id = message.from_user.id
    url = message.text.strip()
    
    if not check_channel_subscription(user_id):
        bot.send_message(user_id, "⚠️ Avval kanallarga a'zo bo'ling.", reply_markup=get_subscription_keyboard())
        return

    # Tizim yuklovchi format turini aniqlash
    mode = 'video'
    db_type = 'video'
    
    # YouTube audio so'rovi uchun qo'shimcha inline panel yaratish
    if "youtube.com" in url or "youtu.be" in url:
        kb = types.InlineKeyboardMarkup(row_width=2)
        kb.add(
            types.InlineKeyboardButton("🎬 Video (MP4)", callback_data=f"ytdl_v||{url}"),
            types.InlineKeyboardButton("🎵 Audio (MP3)", callback_data=f"ytdl_a||{url}")
        )
        bot.send_message(user_id, "🎥 YouTube havolasi aniqlandi. Formatingizni tanlang:", reply_markup=kb)
        return

    # Instagram yoki TikTok yuklash jarayoni to'g'ridan-to'g'ri video formatda ketadi
    is_prem, _ = db.check_premium(user_id)
    if not is_prem:
        used = db.get_daily_usage(user_id, db_type)
        limit_max = DAILY_VIDEO_LIMIT if db_type == 'video' else DAILY_AUDIO_LIMIT
        if used >= limit_max:
            bot.send_message(user_id, f"❌ <b>Kunlik yuklash limitingiz ({limit_max} ta) tugadi!</b>\nPremium sotib olish uchun adminga murojaat qiling.")
            return

    status_msg = bot.send_message(user_id, "⏳ <b>Havola tahlil qilinmoqda va yuklanmoqda...</b>")
    
    # Yuklash oqimi
    res = download_media_ytdlp(url, mode=mode)
    
    if res['status']:
        filepath = res['filepath']
        title = res['title']
        
        try:
            bot.set_my_commands
            if os.path.exists(filepath):
                # Telegram orqali yuborish hajmini tekshirish (Max 50MB)
                file_size = os.path.getsize(filepath) / (1024 * 1024)
                if file_size > 50.0:
                    bot.send_message(user_id, f"⚠️ <b>Fayl hajmi juda katta ({file_size:.1f} MB)!</b>\nTelegram botlari orqali faqat 50MB gacha bo'lgan fayllarni yuborish mumkin.")
                else:
                    bot.send_chat_action(user_id, 'upload_video')
                    with open(filepath, 'rb') as video_file:
                        bot.send_video(user_id, video_file, caption=f"🎬 <b>{title}</b>\n\n📥 @{bot.get_me().username} orqali yuklandi")
                    
                    db.log_download(user_id, db_type, url)
                    dl_logger.info(f"User {user_id} successfully downloaded video: {url}")
            else:
                bot.send_message(user_id, "❌ Fayl yuklashda xatolik: fayl topilmadi.")
        except Exception as send_err:
            err_logger.error(f"Fayl yuborishda xatolik: {send_err}")
            bot.send_message(user_id, "❌ Yuklangan faylni yuborishda muammo yuz berdi.")
        finally:
            if os.path.exists(filepath):
                os.remove(filepath)
    else:
        bot.send_message(user_id, "❌ <b>Media yuklab olishda muammo yuz berdi.</b>\nHavola noto'g'ri yoki sayt himoyasi mavjud.")
        
    bot.delete_message(chat_id=user_id, message_id=status_msg.message_id)
    clean_old_downloads()

@bot.callback_query_handler(func=lambda call: call.data.startswith("ytdl_"))
def youtube_callback_handler(call):
    user_id = call.from_user.id
    data_parts = call.data.split("||")
    action = data_parts[0]
    url = data_parts[1]
    
    mode = 'video' if action == 'ytdl_v' else 'audio'
    db_type = 'video' if mode == 'video' else 'audio'
    
    is_prem, _ = db.check_premium(user_id)
    if not is_prem:
        used = db.get_daily_usage(user_id, db_type)
        limit_max = DAILY_VIDEO_LIMIT if db_type == 'video' else DAILY_AUDIO_LIMIT
        if used >= limit_max:
            bot.answer_callback_query(call.id, "Kunlik limit tugagan!", show_alert=True)
            return

    bot.delete_message(chat_id=user_id, message_id=call.message.message_id)
    status_msg = bot.send_message(user_id, f"📥 <b>YouTube yuklanmoqda ({mode.upper()})... Iltimos kuting.</b>")
    
    res = download_media_ytdlp(url, mode=mode)
    if res['status']:
        filepath = res['filepath']
        title = res['title']
        
        try:
            if os.path.exists(filepath):
                file_size = os.path.getsize(filepath) / (1024 * 1024)
                if file_size > 50.0:
                    bot.send_message(user_id, f"⚠️ <b>Fayl hajmi juda katta ({file_size:.1f} MB)!</b> Telegram cheklovi tufayli yuborilmadi.")
                else:
                    if mode == 'video':
                        bot.send_chat_action(user_id, 'upload_video')
                        with open(filepath, 'rb') as vf:
                            bot.send_video(user_id, vf, caption=f"🎬 <b>{title}</b>\n\n📥 @{bot.get_me().username}")
                    else:
                        bot.send_chat_action(user_id, 'upload_audio')
                        with open(filepath, 'rb') as af:
                            bot.send_audio(user_id, af, caption=f"🎵 <b>{title}</b>\n\n📥 @{bot.get_me().username}")
                    
                    db.log_download(user_id, db_type, url)
                    dl_logger.info(f"User {user_id} downloaded YT {mode}: {url}")
            else:
                bot.send_message(user_id, "❌ Fayl tizimda topilmadi.")
        except Exception as e:
            err_logger.error(f"YT yuborishda xato: {e}")
            bot.send_message(user_id, "❌ Faylni yuborish jarayonida uzilish ro'y berdi.")
        finally:
            if os.path.exists(filepath):
                os.remove(filepath)
    else:
        bot.send_message(user_id, "❌ Yuklash bajarilmadi. Havolani qayta tekshiring.")
        
    bot.delete_message(chat_id=user_id, message_id=status_msg.message_id)
    clean_old_downloads()

# ==========================================
# ADVANCED ADMIN PANEL CONTROL
# ==========================================
@bot.message_handler(func=lambda msg: msg.text == "⚙️ Admin Panel" and msg.from_user.id == ADMIN_ID)
@bot.message_handler(commands=['admin'])
def admin_panel_root(message):
    if message.from_user.id != ADMIN_ID:
        return
    
    admin_menu = (
        "🛠 <b>Professional Admin Panelga Xush Kelibsiz!</b>\n\n"
        "👑 <b>Buyruqlar ro'yxati:</b>\n"
        "📊 /stats - Bot statistikasi\n"
        "👥 /users - Barcha foydalanuvchilar soni\n"
        "🚀 /broadcast - Barcha foydalanuvchilarga xabar yuborish\n"
        "➕ /premium [ID] [KUN] - Premium berish\n"
        "➖ /unpremium [ID] - Premium bekor qilish\n"
        "🚫 /ban [ID] - Bloklash\n"
        "🟢 /unban [ID] - Blokdan chiqarish"
    )
    bot.send_message(ADMIN_ID, admin_menu)

@bot.message_handler(commands=['stats'])
def admin_stats_handler(message):
    if message.from_user.id != ADMIN_ID:
        return
    
    st = db.get_stats()
    
    top_users_str = ""
    for idx, row in enumerate(st['top_users'], start=1):
        top_users_str += f"  {idx}. ID: <code>{row['user_id']}</code> - {row['cnt']} ta yuklanma\n"
        
    stats_text = (
        f"📊 <b>Botning Real-Vaqt Statistikasi:</b>\n\n"
        f"👥 <b>Jami a'zolar:</b> {st['total_users']} ta\n"
        f"📈 <b>Bugun qo'shilganlar:</b> {st['today_users']} ta\n"
        f"👑 <b>Premium a'zolar:</b> {st['premium_users']} ta\n"
        f"📥 <b>Jami yuklangan media:</b> {st['total_downloads']} ta\n\n"
        f"🏆 <b>Eng faol foydalanuvchilar:</b>\n{top_users_str if top_users_str else ' Hozircha mavjud emas.'}"
    )
    bot.send_message(ADMIN_ID, stats_text)

@bot.message_handler(commands=['users'])
def admin_users_count(message):
    if message.from_user.id != ADMIN_ID:
        return
    st = db.get_stats()
    bot.send_message(ADMIN_ID, f"👥 Bot foydalanuvchilari jami soni: <b>{st['total_users']}</b> ta.")

@bot.message_handler(commands=['premium'])
def admin_give_premium_handler(message):
    if message.from_user.id != ADMIN_ID:
        return
    
    try:
        parts = message.text.split()
        if len(parts) < 3:
            bot.send_message(ADMIN_ID, "⚠️ Format: `/premium [Foydalanuvchi_ID] [Kun_Soni]`")
            return
            
        target_id = int(parts[1])
        days = int(parts[2])
        
        db.give_premium(target_id, days)
        bot.send_message(ADMIN_ID, f"✅ ID: <code>{target_id}</code> bo'lgan foydalanuvchiga {days} kunga premium berildi!")
        
        # Foydalanuvchini ogohlantirish
        try:
            bot.send_message(target_id, f"🎉 <b>Tabriklaymiz! Admin sizga {days} kunga Premium statusini berdi.</b>\nEndi sizda barcha limitlar cheksiz!")
        except Exception:
            pass
    except Exception as e:
        bot.send_message(ADMIN_ID, f"❌ Xatolik yuz berdi: {e}")

@bot.message_handler(commands=['unpremium'])
def admin_remove_premium_handler(message):
    if message.from_user.id != ADMIN_ID:
        return
        
    try:
        parts = message.text.split()
        if len(parts) < 2:
            bot.send_message(ADMIN_ID, "⚠️ Format: `/unpremium [Foydalanuvchi_ID]`")
            return
            
        target_id = int(parts[1])
        db.remove_premium(target_id)
        bot.send_message(ADMIN_ID, f"✅ ID: <code>{target_id}</code> bo'lgan foydalanuvchidan premium olib tashlandi.")
    except Exception as e:
        bot.send_message(ADMIN_ID, f"❌ Xatolik yuz berdi: {e}")

@bot.message_handler(commands=['ban'])
def admin_ban_handler(message):
    if message.from_user.id != ADMIN_ID:
        return
    try:
        parts = message.text.split()
        if len(parts) < 2:
            bot.send_message(ADMIN_ID, "⚠️ Format: `/ban [Foydalanuvchi_ID]`")
            return
        target_id = int(parts[1])
        db.set_ban(target_id, 1)
        bot.send_message(ADMIN_ID, f"🚫 ID: <code>{target_id}</code> bloklandi.")
    except Exception as e:
        bot.send_message(ADMIN_ID, f"❌ Xatolik: {e}")

@bot.message_handler(commands=['unban'])
def admin_unban_handler(message):
    if message.from_user.id != ADMIN_ID:
        return
    try:
        parts = message.text.split()
        if len(parts) < 2:
            bot.send_message(ADMIN_ID, "⚠️ Format: `/unban [Foydalanuvchi_ID]`")
            return
        target_id = int(parts[1])
        db.set_ban(target_id, 0)
        bot.send_message(ADMIN_ID, f"🟢 ID: <code>{target_id}</code> blokdan chiqarildi.")
    except Exception as e:
        bot.send_message(ADMIN_ID, f"❌ Xatolik: {e}")

# ==========================================
# SMART BROADCAST SYSTEM (XABAR YUBORISH)
# ==========================================
@bot.message_handler(commands=['broadcast'])
def admin_broadcast_trigger(message):
    if message.from_user.id != ADMIN_ID:
        return
    sent = bot.send_message(ADMIN_ID, "📝 <b>Barcha foydalanuvchilarga yuboriladigan xabarni kiriting (Matn, rasm yoki video):</b>")
    bot.register_next_step_handler(sent, process_admin_broadcast)

def process_admin_broadcast(message):
    if message.from_user.id != ADMIN_ID:
        return
        
    all_users = db.get_all_users()
    bot.send_message(ADMIN_ID, f"🚀 <b>Xabar yuborish boshlandi... Jami manzillar: {len(all_users)}</b>")
    
    success = 0
    failed = 0
    
    for u_id in all_users:
        try:
            if message.content_type == 'text':
                bot.send_message(u_id, message.text, parse_mode="HTML")
            elif message.content_type == 'photo':
                bot.send_photo(u_id, message.photo[-1].file_id, caption=message.caption, parse_mode="HTML")
            elif message.content_type == 'video':
                bot.send_video(u_id, message.video.file_id, caption=message.caption, parse_mode="HTML")
            success += 1
            # Telegram Flood limitlariga tushmaslik uchun kichik kechikish
            time.sleep(0.05)
        except Exception:
            failed += 1
            continue
            
    bot.send_message(ADMIN_ID, f"📢 <b>Xabar yuborish yakunlandi!</b>\n\n✅ Muvaffaqiyatli: {success}\n❌ Muammoli: {failed}")

# ==========================================
# APPLICATION BOOTSTRAPPER (INFINITY POLLING)
# ==========================================
if __name__ == "__main__":
    db.write_system_log("INFO", "Bot muvaffaqiyatli ishga tushirildi.")
    print(">>> Universal Telegram Media Bot muvaffaqiyatli ishlamoqda...")
    
    # Botni cheksiz tsiklda qayta-qayta ishga tushirish (Termux/VPS xavfsizligi)
    while True:
        try:
            bot.infinity_polling(timeout=60, long_polling_timeout=30)
        except Exception as global_err:
            err_logger.error(f"Infinity polling global xatosi: {global_err}")
            db.write_system_log("CRITICAL", f"Polling uzilishi: {str(global_err)}")
            time.sleep(5)  # Qayta ulanishdan oldin kutish
